    "dev": "vite build --watch",
    "test": "vitest --run"
  },
  "peerDependencies": {
    "ckeditor5": ">=43.0.0"
  },
  "dependencies": {
    "@nl-design-system-community/editor": "workspace:*"
  },
  "devDependencies": {
    "@nl-design-system/tsconfig": "1.0.5",
    "@types/node": "22.20.1",
    "ckeditor5": "48.3.1",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vite-plugin-dts": "5.0.3",
    "vitest": "4.1.9"
  }
