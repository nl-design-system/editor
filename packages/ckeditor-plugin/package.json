{
  "name": "@nl-design-system-community/ckeditor-plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/nl-design-system/editor.git",
    "directory": "packages/ckeditor-plugin"
  },
  "keywords": [
    "expertteam-digitale-toegankelijkheid",
    "nl-design-system"
  ],
  "version": "0.0.2",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "main": "./dist/index.js",
