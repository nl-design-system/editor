---
import Document from '../layouts/document.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import CardGroup from '../components/CardGroup.astro';
import { frontmatter as indexFrontmatter } from '../../../../docs/index.md';
import { useTranslations } from '../i18n/translations.ts';

const t = useTranslations('nl');
---

<Document title={t('integrations.title')}>
  <main>
    <Hero title={indexFrontmatter['title']} intro={indexFrontmatter['intro']} />

    <Section>
      <CardGroup>
        <Card heading="Drupal">
          <p>
            Integreer Clippy in Drupal door de <code>ClippyPlugin</code> toe te voegen aan de CKEditor-configuratie. Zo zijn
            de toegankelijkheidsvalidaties direct beschikbaar voor redacteurs.
          </p>
        </Card>

        <Card heading="CKEditor" href="/ckeditor">
          <p>
            Clippy Editor biedt een CKEditor 5-plugin waarmee je de toegankelijkheidsvalidaties van Clippy kunt
            toevoegen aan elke CKEditor-instantie. De plugin is beschikbaar als
            <code>@nl-design-system-community/ckeditor-plugin</code>.
          </p>
        </Card>
      </CardGroup>
    </Section>
  </main>
</Document>
