---
import Document from '../layouts/document.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import {
  Content as ConfigurationContent,
  frontmatter as configurationFrontmatter,
} from '../../../../docs/configuration/configuration.md';
import { Content as ConfigurationSection } from '../../../../docs/configuration/examples/live-example.md';
import { useTranslations } from '../i18n/translations.ts';
import { ToolbarConfigurator } from '../components/ToolbarConfigurator';

const t = useTranslations('nl');
---

<Document title={t('configuration.title')}>
  <main>
    <Hero title={configurationFrontmatter['title']} intro={configurationFrontmatter['intro']} />

    <Section content={ConfigurationContent}>
      <clippy-editor
        id="clippy-editor-minimal-toolbar"
        toolbar-config='[["bold","italic","underline"],["undo","redo"],["link"]]'
      >
        <div slot="value">
          <p>Inhoud hier...</p>
        </div>
      </clippy-editor>
    </Section>

    <Section content={ConfigurationSection}>
      <ToolbarConfigurator client:only="react" />
    </Section>
  </main>
</Document>
