---
import Document from '../layouts/document.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import MermaidDiagram from '../components/MermaidDiagram.astro';
import { useTranslations } from '../i18n/translations.ts';
import { altTextWizardMachine } from '@nl-design-system-community/clippy-alt-text-wizard/state-machine';
import { generateMermaidStateDiagram } from '../utils/generateMermaidStateDiagram.ts';

const t = useTranslations('nl');
const mermaid = generateMermaidStateDiagram(altTextWizardMachine);
---

<Document title={t('alt-text-wizard.title')}>
  <main>
    <Hero title="Alt-tekst wizard" intro="Een stapsgewijze wizard die auteurs helpt bij het schrijven van toegankelijke alt-teksten voor afbeeldingen." />

    <Section>
      <h2>Demo</h2>
      <div class="clippy-alt-text-wizard-card">
        <clippy-alt-text-wizard></clippy-alt-text-wizard>
      </div>
    </Section>

    <Section>
      <h2>Beslisboom</h2>
      <p>
        De wizard leidt gebruikers door een ja/nee-beslisboom. Het onderstaande diagram wordt automatisch gegenereerd
        vanuit de <a href="https://stately.ai/docs">XState</a> state machine.
      </p>
      <MermaidDiagram diagram={mermaid} />
    </Section>
  </main>
</Document>

<script>
  import '@nl-design-system-community/clippy-alt-text-wizard';
</script>

<style>
  .clippy-alt-text-wizard-card {
    background-color: var(--basis-color-default-bg-document);
    box-shadow: var(--basis-box-shadow-md);
    padding-block: var(--basis-space-block-3xl);
    padding-inline: var(--basis-space-inline-3xl);
  }
</style>
