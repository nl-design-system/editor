---
import Document from '../layouts/document.astro';
---

<Document title="Toolbar configuratie - Rich-text Editor - NL Design System">

  <main>
    <section class="ma-banner ma-banner--hero">
      <div class="ma-banner__content">
        <header class="ma-banner__header">
          <h1 class="utrecht-heading-1">Toolbar configuratie</h1>
        </header>
        <div class="ma-banner__copy">
          <p class="utrecht-paragraph">
            De toolbar kan geconfigureerd worden via het <code>toolbar-config</code> attribuut. Dit attribuut accepteert
            een JSON-array van groepen, waarbij elke groep een array van <code>items</code> is.
          </p>
        </div>
      </div>
    </section>

    <section class="ma-page-section ma-page-section--with-space">
      <h2 class="utrecht-heading-2">Custom toolbar configuratie</h2>
      <p class="utrecht-paragraph">
        Hieronder staat een editor met een custom toolbar configuratie: alleen tekststijlen en een link-knop.
      </p>

      <clippy-editor
        id="clippy-editor-minimal-toolbar"
        toolbar-config='[["bold","italic","underline"],["undo","redo"],["link"]]'
      >
        <div slot="content">
          <p>Inhoud hier...</p>
        </div>
      </clippy-editor>

      <h3 class="utrecht-heading-3">Voorbeeld HTML</h3>
      <pre class="utrecht-code-block"><code>&lt;clippy-editor
  toolbar-config='[
    ["bold", "italic", "underline"],
    ["undo", "redo"],
    ["link"]
  ]'
&gt;
  &lt;div slot="content"&gt;
    &lt;p&gt;Inhoud hier...&lt;/p&gt;
  &lt;/div&gt;
&lt;/clippy-editor&gt;</code></pre>

      <h2 class="utrecht-heading-2">Live configuratie demo</h2>
      <p class="utrecht-paragraph">Pas de JSON hieronder aan en zie de toolbar direct veranderen.</p>
      <div class="clippy-toolbar-config-demo">
        <label class="utrecht-form-label" for="toolbar-config-input">Toolbar configuratie (JSON)</label>
        <textarea
          id="toolbar-config-input"
          class="clippy-json-textarea"
          rows="14"
          spellcheck="false"
          autocomplete="off"
          aria-describedby="toolbar-config-error"
        ></textarea>
        <p id="toolbar-config-error" class="clippy-json-error-message" hidden aria-live="polite"></p>
      </div>
      <clippy-editor id="clippy-editor-live-config">
        <div slot="content">
          <p>Pas de JSON aan om de toolbar live te wijzigen.</p>
        </div>
      </clippy-editor>
    </section>
  </main>
</Document>

<script>
  (function () {
    const defaultConfig = [
      ['bold', 'italic', 'underline', 'strike', 'code'],
      ['undo', 'redo'],
      ['ordered-list', 'bullet-list'],
      ['link', 'horizontal-rule'],
    ];

    const textarea = document.getElementById('toolbar-config-input') as HTMLTextAreaElement | null;
    const errorEl = document.getElementById('toolbar-config-error');
    const editor = document.getElementById('clippy-editor-live-config');

    if (!textarea || !errorEl || !editor) return;

    textarea.value = JSON.stringify(defaultConfig, null, 2);

    function applyConfig(value: string) {
      try {
        const parsed = JSON.parse(value) as unknown;
        editor!.setAttribute('toolbar-config', JSON.stringify(parsed));
        errorEl!.textContent = '';
        (errorEl as HTMLElement).hidden = true;
        textarea!.removeAttribute('aria-invalid');
      } catch (e) {
        errorEl!.textContent = 'Ongeldige JSON: ' + (e as Error).message;
        (errorEl as HTMLElement).hidden = false;
        textarea!.setAttribute('aria-invalid', 'true');
      }
    }

    customElements.whenDefined('clippy-editor').then(() => {
      applyConfig(textarea!.value);
    });

    textarea.addEventListener('input', () => {
      applyConfig(textarea!.value);
    });
  })();
</script>

