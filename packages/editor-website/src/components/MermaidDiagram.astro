---
interface Props {
  diagram: string;
}

const { diagram } = Astro.props;
---

<pre class="mermaid">{diagram}</pre>

<script is:inline src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
<script is:inline>
  mermaid.initialize({ startOnLoad: true, theme: 'neutral' });
</script>
