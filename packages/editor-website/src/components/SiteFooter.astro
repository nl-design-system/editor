---
import SiteLogo from './SiteLogo.astro';
import type { Locale } from '../i18n/translations.ts';
import { useTranslations } from '../i18n/translations.ts';

const locale = (Astro.currentLocale ?? 'nl') as Locale;
const t = useTranslations(locale);
---

<footer class="clippy-website-footer">
  <div class="clippy-website-footer__inner">
    <div class="clippy-website-footer__logo">
      <SiteLogo href={t('nav.href.editor')} ariaLabel={t('site.logo.label')} />
    </div>

    <div class="clippy-website-footer__about">
      <p>
        {t('footer.about')}{' '}
        <a href="https://nldesignsystem.nl">NL Design System</a>.
      </p>
    </div>

    <nav class="clippy-website-footer__nav" aria-label={t('footer.nav.label')}>
      <a class="clippy-website-footer__nav-link" href={t('footer.contact.href')}>{t('footer.contact')}</a>
      <a class="clippy-website-footer__nav-link" href={t('footer.privacy.href')}>{t('footer.privacy')}</a>
      <a class="clippy-website-footer__nav-link" href={t('footer.accessibility.href')}>{t('footer.accessibility')}</a>
    </nav>
  </div>
</footer>

<style>
  .clippy-website-footer {
    background-color: var(--basis-color-accent-1-color-default);
    color: var(--basis-color-accent-1-inverse-color-document);
  }

  .clippy-website-footer__inner {
    align-items: start;
    display: grid;
    gap: var(--basis-space-inline-5xl);
    grid-template-columns: auto 1fr auto;
    margin-inline: auto;
    max-inline-size: var(--basis-page-max-inline-size);
    padding-block: var(--basis-space-block-3xl);
    padding-inline: var(--basis-space-inline-2xl);
  }

  .clippy-website-footer__about a {
    color: inherit;
  }

  .clippy-website-footer__about p {
    margin-block: 0;
  }

  .clippy-website-footer__nav {
    display: flex;
    flex-direction: column;
    gap: var(--basis-space-block-sm);
  }

  .clippy-website-footer__nav-link {
    color: inherit;
    font-size: var(--basis-text-font-size-md);
  }
</style>
