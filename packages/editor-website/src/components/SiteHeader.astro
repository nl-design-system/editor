---
import SiteLogo from './SiteLogo.astro';
import type { Locale } from '../i18n/translations.ts';
import { useTranslations } from '../i18n/translations.ts';

const locale = (Astro.currentLocale ?? 'nl') as Locale;
const t = useTranslations(locale);

const navItems = [
  { href: t('nav.href.editor'), label: t('nav.editor') },
  { href: t('nav.href.configuration'), label: t('nav.configuration') },
  { href: t('nav.href.guidelines'), label: t('nav.guidelines') },
  { href: t('nav.href.react'), label: t('nav.react') },
  { href: t('nav.href.integrations'), label: t('nav.integrations') },
  { href: t('nav.href.alt-text-wizard'), label: t('nav.alt-text-wizard') },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

// Determine the root path for "active" check per locale
const localeRoot = locale === 'en' ? '/en' : '/';
---

<header class="ma-site-header">
    <div class="ma-site-header__logo">
      <SiteLogo href={t('nav.href.editor')} ariaLabel={t('site.logo.label')} />
    </div>
    <nav class="ma-site-header__nav" aria-label={t('nav.label')}>
      <ul class="ma-site-header__nav-list" role="list">
        {
          navItems.map(({ href, label }) => {
            const isActive =
              href === localeRoot
                ? currentPath === localeRoot
                : currentPath.startsWith(href);
            return (
              <li>
                <a
                  class={`ma-site-header__nav-link${isActive ? ' ma-site-header__nav-link--active' : ''}`}
                  href={href}
                  aria-current={isActive ? 'page' : undefined}
                >
                  {label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
    <nav class="ma-site-header__lang-nav" aria-label={t('nav.language.label')}>
      <a class="ma-site-header__lang-link" href={t('nav.href.language')} hreflang={locale === 'en' ? 'nl' : 'en'}>
        {t('nav.language')}
      </a>
    </nav>
</header>

<style>
  .ma-site-header {
    background-color: var(--basis-color-accent-1-color-default);
    color: var(--basis-color-accent-1-inverse-color-document);
    align-items: stretch;
    justify-content: space-between;
    display: flex;
    gap: var(--basis-space-inline-xl);
  }

  .ma-site-header__logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    padding-block: var(--basis-space-block-lg);
    padding-inline: var(--basis-space-inline-lg);
  }

  .ma-site-header__nav {
    display: flex;
    align-self: stretch;
    align-items: stretch;
  }

  .ma-site-header__nav-list {
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ma-site-header__nav-link {
    font-weight: var(--basis-text-font-weight-bold);
    box-sizing: border-box;
    display: flex;
    align-items: center;
    padding-block: var(--basis-space-block-md);
    padding-inline: var(--basis-space-inline-xl);
    block-size: 100%;
    color: inherit;
    font-size: var(--basis-text-font-size-md);
    text-decoration: none;
  }

  .ma-site-header__nav-link:hover {
    background-color: var(--basis-color-accent-1-color-hover);
  }

  .ma-site-header__nav-link--active {
    background-color: var(--basis-color-accent-1-color-active);
    border-block-end: var(--basis-border-width-md) solid var(--basis-color-default-inverse-border-default);
  }

  .ma-site-header__lang-nav {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    padding-block: var(--basis-space-block-md);
    padding-inline: var(--basis-space-inline-xl);
  }

  .ma-site-header__lang-link {
    color: inherit;
    font-size: var(--basis-text-font-size-md);
    text-decoration: none;
  }

  .ma-site-header__lang-link:hover {
    text-decoration: underline;
  }
</style>
