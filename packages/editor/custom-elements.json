      "declarations": [
        {
          "kind": "class",
          "description": "The editable content area of the rich text editor. It is a separate element\nso consumers can decide where it appears in the page layout.\n\nBy default the TipTap `ProseMirror` DOM is mounted directly into the Light DOM\nof this element so that standard browser stylesheets apply. Pass the `shadow`\nattribute to mount inside the Shadow DOM instead (experimental).\n\nThe element requires a TipTap editor context (provided by `<clippy-editor>`)\nto be present in an ancestor.",
          "name": "Content",
          "members": [
            {
              "kind": "field",
              "name": "shadow",
              "type": {
                "text": "boolean | undefined"
              },
              "privacy": "public",
              "description": "When present, mounts the ProseMirror view inside the Shadow DOM instead of\nthe Light DOM. Experimental — use with care.",
              "attribute": "shadow"
            },
            {
              "kind": "field",
              "name": "inline",
              "type": {
                "text": "boolean | undefined"
              },
              "privacy": "public",
              "description": "When `true`, the host element and its ProseMirror children are rendered as\n`display: inline` so the editor can be embedded inside flowing text.",
              "attribute": "inline"
            }
          ],
          "attributes": [
            {
              "name": "shadow",
