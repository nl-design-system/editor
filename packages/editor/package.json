{
  "name": "@nl-design-system-community/editor",
  "repository": {
    "type": "git",
    "url": "https://github.com/nl-design-system/editor.git",
    "directory": "packages/editor"
  },
  "keywords": [
    "expertteam-digitale-toegankelijkheid",
    "nl-design-system"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "version": "1.4.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./toolbar": {
      "types": "./dist/toolbar.d.ts",
      "default": "./dist/toolbar.js"
    },
    "./theme.css": "./theme.css"
  },
  "typesVersions": {
    "*": {
      "toolbar": [
        "./dist/toolbar.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "theme.css"
  ],
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "vite",
    "build": "npm-run-all build:ts build:vite",
    "build:analyze": "cross-env ANALYZE_BUNDLE=true vite build",
    "build:ts": "tsc --build",
    "build:vite": "vite build",
    "preview": "vite preview",
    "test": "pnpm run '/^test:.+$/'",
    "test:vitest": "vitest --run",
    "test-coverage": "vitest run --coverage",
    "localize:extract": "lit-localize extract",
    "localize:build": "lit-localize build"
  },
  "dependencies": {
    "@lit/context": "1.1.6",
    "@lit/localize": "0.12.2",
    "@nl-design-system-candidate/button-css": "1.1.0",
    "@nl-design-system-candidate/data-badge-css": "1.0.5",
    "@nl-design-system-candidate/link-css": "2.0.3",
    "@nl-design-system-candidate/number-badge-css": "1.1.5",
    "@nl-design-system-community/clippy-components": "2.0.0",
    "@tabler/icons": "3.41.1",
    "@tiptap/core": "3.20.0",
    "@tiptap/extension-blockquote": "3.20.0",
    "@tiptap/extension-bold": "3.20.0",
    "@tiptap/extension-bubble-menu": "3.20.0",
    "@tiptap/extension-code": "3.20.0",
    "@tiptap/extension-code-block": "3.20.0",
    "@tiptap/extension-document": "3.20.0",
    "@tiptap/extension-dropcursor": "3.20.0",
    "@tiptap/extension-file-handler": "3.20.0",
    "@tiptap/extension-hard-break": "3.20.0",
    "@tiptap/extension-heading": "3.20.0",
    "@tiptap/extension-highlight": "3.20.0",
    "@tiptap/extension-horizontal-rule": "3.20.0",
    "@tiptap/extension-image": "3.20.0",
    "@tiptap/extension-italic": "3.20.0",
    "@tiptap/extension-link": "3.20.0",
    "@tiptap/extension-list": "3.20.0",
    "@tiptap/extension-paragraph": "3.20.0",
    "@tiptap/extension-strike": "3.20.0",
    "@tiptap/extension-subscript": "3.20.0",
    "@tiptap/extension-superscript": "3.20.0",
    "@tiptap/extension-table": "3.20.0",
    "@tiptap/extension-text": "3.20.0",
    "@tiptap/extension-text-align": "3.20.0",
    "@tiptap/extension-text-style": "3.20.0",
    "@tiptap/extension-underline": "3.20.0",
    "@tiptap/extensions": "3.20.0",
    "@tiptap/pm": "3.20.0",
    "@utrecht/blockquote-css": "2.0.1",
    "@utrecht/drawer-css": "2.0.1",
    "@utrecht/form-field-css": "2.0.1",
    "@utrecht/form-label-css": "2.0.1",
    "@utrecht/img-css": "2.0.1",
    "@utrecht/ordered-list-css": "3.0.1",
    "@utrecht/separator-css": "2.0.1",
    "@utrecht/subscript-css": "2.0.1",
    "@utrecht/superscript-css": "2.0.1",
    "@utrecht/table-css": "2.0.2",
    "@utrecht/textbox-css": "3.1.0",
    "@utrecht/unordered-list-css": "2.0.1",
    "lit": "3.3.2",
    "prosemirror-model": "1.25.4"
  },
  "devDependencies": {
    "@fontsource/fira-sans": "5.2.7",
    "@fontsource/source-sans-pro": "5.2.5",
    "@lit/localize-tools": "0.8.1",
    "@nl-design-system-candidate/code-block-css": "1.1.5",
    "@nl-design-system-candidate/code-css": "2.0.5",
    "@nl-design-system-candidate/heading-css": "1.1.3",
    "@nl-design-system-candidate/mark-css": "1.0.5",
    "@nl-design-system-candidate/paragraph-css": "2.1.3",
    "@nl-design-system-community/ma-design-tokens": "4.1.0",
    "@nl-design-system/tsconfig": "1.0.5",
    "@testing-library/dom": "10.4.1",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.19.15",
    "@types/query-selector-shadow-dom": "1.0.4",
    "@utrecht/design-tokens": "5.0.2",
    "@vitest/browser-playwright": "4.1.2",
    "@vitest/coverage-v8": "4.1.2",
    "cross-env": "10.1.0",
    "npm-run-all": "4.1.5",
    "postcss-lit": "1.4.1",
    "query-selector-shadow-dom": "1.0.1",
    "typescript": "5.9.3",
    "vite": "8.0.3",
    "vite-plugin-dts": "4.5.4",
    "vitest": "4.1.2"
  }
}
