{
  "name": "@nl-design-system-community/clippy-alt-text-wizard",
  "repository": {
    "type": "git",
    "url": "https://github.com/nl-design-system/editor.git",
    "directory": "packages/clippy-alt-text-wizard"
  },
  "keywords": [
    "expertteam-digitale-toegankelijkheid",
    "nl-design-system"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./state-machine": {
      "types": "./dist/state-machine.d.ts",
      "default": "./dist/state-machine.js"
    }
  },
  "customElements": "dist/custom-elements.json",
  "files": [
    "dist"
  ],
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "vite",
    "build": "pnpm run build:ts && pnpm run build:vite && pnpm run build:cem",
    "build:cem": "cem analyze --config custom-elements-manifest.config.mjs --litelement",
    "build:ts": "tsc --build",
    "build:vite": "vite build",
    "localize:extract": "lit-localize extract",
    "localize:build": "lit-localize build"
  },
  "dependencies": {
    "@lit/localize": "0.12.2",
    "@nl-design-system-community/clippy-components": "3.1.0",
    "lit": "3.3.3",
    "xstate": "5.32.1"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "0.11.0",
    "@fontsource/fira-sans": "5.2.7",
    "@fontsource/source-sans-pro": "5.2.5",
    "@lit/localize-tools": "0.8.2",
    "@nl-design-system-candidate/button-css": "1.1.0",
    "@nl-design-system-candidate/code-block-css": "1.2.0",
    "@nl-design-system-candidate/code-css": "3.0.0",
    "@nl-design-system-candidate/heading-css": "1.1.3",
    "@nl-design-system-candidate/link-css": "2.0.3",
    "@nl-design-system-candidate/paragraph-css": "2.1.3",
    "@nl-design-system-community/ma-design-tokens": "5.2.0",
    "@nl-design-system/tsconfig": "1.0.5",
    "@tabler/icons": "3.44.0",
    "@types/node": "22.19.19",
    "@utrecht/design-tokens": "6.2.1",
    "@utrecht/form-field-css": "3.0.1",
    "@utrecht/form-field-description-css": "3.0.1",
    "@utrecht/form-label-css": "3.0.1",
    "@utrecht/radio-button-css": "3.0.1",
    "@utrecht/unordered-list-css": "3.1.1",
    "typescript": "5.9.3",
    "vite": "8.0.16",
    "vite-plugin-dts": "5.0.2"
  }
}
